# Base URL for the GINHAWA cloud API. The dev cloud listens on
# localhost:8000; production deployments override this. The portal
# defaults to http://127.0.0.1:8000 when the var is absent, so this
# file is mostly documentation — copy to .env.development if you
# need to point a dev portal at a non-default cloud instance.
VITE_CLOUD_API_URL=http://127.0.0.1:8000
