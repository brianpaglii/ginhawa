# Template for scripts/.bench_mqtt_secrets (gitignored).
# Copy to .bench_mqtt_secrets and fill in the passwords issued on the
# Pi via:
#   sudo mosquitto_passwd /etc/mosquitto/passwd esp32_a
#   sudo mosquitto_passwd /etc/mosquitto/passwd esp32_b
# Used by scripts/bench_mqtt_publish.sh.

ESP32_A_PASS=set-by-mosquitto-passwd
ESP32_B_PASS=set-by-mosquitto-passwd
