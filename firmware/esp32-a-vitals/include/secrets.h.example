// Copy this file to secrets.h and fill in the deployment values.
// secrets.h is gitignored — do NOT commit real credentials.
//
// MQTT credentials are issued by the kiosk operator with
// `mosquitto_passwd /etc/mosquitto/passwd esp32_a` on the Pi; the ACL
// for this user only permits publishing the three topic suffixes
// owned by ESP32-A (spo2, heart_rate, temperature). See
// scripts/bench_mqtt_publish.sh for a worked round-trip.
#pragma once

#define WIFI_SSID "Infocus"
#define WIFI_PASS "your-wifi-password"

#define MQTT_HOST "192.168.1.119"  // Pi's LAN IP — verify with `ip addr` on Pi
#define MQTT_PORT 1883
#define MQTT_USER "esp32_a"
#define MQTT_PASS "set-by-mosquitto-passwd"

// Must match the kiosk's device_config.kiosk_device_id row. The
// example UUID is the bench-Pi default; production deployments use
// the UUID issued by the cloud admin during device enrolment.
#define KIOSK_DEVICE_ID "00000000-0000-0000-0000-000000000401"
